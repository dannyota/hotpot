# Hotpot Configuration Example
#
# ⚠️  WARNING: This is an EXAMPLE file with PLACEHOLDER values
# ⚠️  DO NOT use these values in production
# ⚠️  Copy to config.yaml and replace ALL placeholders
#
# Quick start with docker compose (deploy/dev/):
#   make dev-up
#   cp config.yaml.example config.yaml
# The defaults below match the dev docker-compose services.
#
# Usage:
#   1. cp config.yaml.example config.yaml
#   2. Replace all <PLACEHOLDER> values
#   3. CONFIG_SOURCE=file CONFIG_FILE=config.yaml ./bin/ingest

# GCP Configuration
gcp:
  # Enable GCP ingestion (default: false)
  enabled: true

  # Service account credentials (JSON format)
  # Optional - falls back to Application Default Credentials (ADC) if not set
  # nosemgrep: generic.secrets.security.detected-generic-secret
  # credentials_json: '{"type":"service_account","project_id":"...","private_key":"..."}'

  # API rate limiting (requests per minute across all GCP clients)
  # Default: 600 if not set
  rate_limit_per_minute: 600

# SentinelOne Configuration
# nosemgrep: generic.secrets.security.detected-generic-secret
s1:
  # Enable SentinelOne ingestion (default: false)
  enabled: false
  # base_url: "https://<YOUR_S1_CONSOLE>.sentinelone.net"
  # api_token: "<YOUR_S1_API_TOKEN>"
  # rate_limit_per_minute: 600  # Default: 600
  # batch_size: 1000            # Default: 1000 (API max)

# AWS Configuration
# nosemgrep: generic.secrets.security.detected-generic-secret
aws:
  # Enable AWS ingestion (default: false)
  enabled: false
  # access_key_id: "<YOUR_AWS_ACCESS_KEY_ID>"       # Optional - falls back to default credential chain
  # secret_access_key: "<YOUR_AWS_SECRET_ACCESS_KEY>"
  # regions: ["us-east-1", "ap-southeast-1"]  # Optional - discovers all regions if not set
  # rate_limit_per_minute: 600  # Default: 600

# DigitalOcean Configuration
# nosemgrep: generic.secrets.security.detected-generic-secret
do:
  # Enable DigitalOcean ingestion (default: false)
  enabled: false
  # api_token: "<YOUR_DO_API_TOKEN>"
  # rate_limit_per_minute: 300  # Default: 300

# GreenNode Configuration
# nosemgrep: generic.secrets.security.detected-generic-secret
greennode:
  # Enable GreenNode ingestion (default: false)
  enabled: false
  # regions: ["hcm-3", "han-1"]
  # project_id: "<YOUR_PROJECT_ID>"
  #
  # Auth option 1: Service account (client_id + client_secret)
  # client_id: "<YOUR_CLIENT_ID>"
  # client_secret: "<YOUR_CLIENT_SECRET>"
  #
  # Auth option 2: IAM user (takes priority over service account when username is set)
  # root_email: "<YOUR_ROOT_EMAIL>"
  # username: "<YOUR_USERNAME>"
  # password: "<YOUR_PASSWORD>"
  # totp_secret: "<YOUR_BASE32_TOTP_SECRET>"  # Optional, for accounts with 2FA
  #
  # rate_limit_per_minute: 300  # Default: 300

# Vault Configuration (PKI certificate ingestion)
# nosemgrep: generic.secrets.security.detected-generic-secret
vault:
  # Enable Vault ingestion (default: false)
  enabled: false
  # rate_limit_per_minute: 60  # Default: 60
  # instances:
  #   - name: "prod-vault"
  #     address: "https://vault.example.com"
  #     token: "<YOUR_VAULT_TOKEN>"
  #     verify_ssl: true  # Default: true

# Jenkins Configuration
# nosemgrep: generic.secrets.security.detected-generic-secret
jenkins:
  # Enable Jenkins ingestion (default: false)
  enabled: false
  # base_url: "https://jenkins.example.com"
  # username: "<YOUR_JENKINS_USERNAME>"
  # api_token: "<YOUR_JENKINS_API_TOKEN>"
  # verify_ssl: true              # Default: true
  # timeout: 30                   # Seconds, default: 30
  # since: "2024-01-01"           # Only process jobs with builds since this date
  # max_builds_per_job: 1000      # Safety cap per run, default: 1000
  # exclude_repos: []             # Repo URL patterns to exclude
  # rate_limit_per_minute: 120    # Default: 120

# Database Configuration (REQUIRED)
# nosemgrep: generic.secrets.security.detected-generic-secret
database:
  host: localhost  # or <YOUR_DATABASE_HOST>
  port: 5432
  user: postgres   # Replace with your database user
  password: postgres  # CHANGEME: Use strong password or Vault in production
  dbname: hotpot_dev
  sslmode: disable  # SECURITY: Use 'require' or 'verify-full' in production
  # sslmode options: disable (dev only), require, verify-ca, verify-full

# Temporal Configuration (REQUIRED)
temporal:
  host_port: localhost:7233  # REQUIRED - Replace with your Temporal server
  namespace: default         # Optional - defaults to "default"

# Redis Configuration (for rate limiting)
# Optional - falls back to in-memory rate limiting if not set
# nosemgrep: generic.secrets.security.detected-generic-secret
redis:
  address: localhost:6379  # or <YOUR_REDIS_HOST>:6379
  password: ""  # No password for dev; set for production
  db: 0  # Optional - defaults to 0
